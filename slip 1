
sudo apt update && sudo apt install bridge-utils iproute2 -y

sudo ip link add bus0 type bridge
sudo ip link set bus0 up

sudo ip netns add pc1
sudo ip netns add pc2
sudo ip netns add pc3

sudo ip link add veth1 type veth peer name veth1-bus
sudo ip link set veth1 netns pc1
sudo ip link set veth1-bus master bus0
sudo ip link set veth1-bus up

sudo ip link add veth2 type veth peer name veth2-bus
sudo ip link set veth2 netns pc2
sudo ip link set veth2-bus master bus0
sudo ip link set veth2-bus up

sudo ip link add veth3 type veth peer name veth3-bus
sudo ip link set veth3 netns pc3
sudo ip link set veth3-bus master bus0
sudo ip link set veth3-bus up

sudo ip netns exec pc1 ip addr add 10.0.0.1/24 dev veth1
sudo ip netns exec pc1 ip link set veth1 up

sudo ip netns exec pc2 ip addr add 10.0.0.2/24 dev veth2
sudo ip netns exec pc2 ip link set veth2 up

sudo ip netns exec pc3 ip addr add 10.0.0.3/24 dev veth3
sudo ip netns exec pc3 ip link set veth3 up

sudo ip netns exec pc1 ping -c 2 10.0.0.2


